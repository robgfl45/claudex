#!/usr/bin/env python3
"""Bounded Drake-owned targeted verification for exact review-v3 findings."""
from __future__ import annotations
import argparse, datetime as dt, importlib.util, json, os, pathlib, shutil, signal, stat, subprocess, sys, tempfile, time
ROOT=pathlib.Path(__file__).resolve().parents[1]
spec=importlib.util.spec_from_file_location("closure_contract",ROOT/"plugins/claudex/scripts/closure_contract.py"); c=importlib.util.module_from_spec(spec); spec.loader.exec_module(c)
EXIT={"accepted_after_targeted_closure":0,"blocked":10,"closure_requires_new_review":10,"degraded":11,"timed_out":124}
ACTIVE=None; INTERRUPTED=False

def emit(obj,code): print(json.dumps(obj,sort_keys=True,separators=(",",":"),ensure_ascii=False)); return code
def atom(path,data):
 fd,tmp=tempfile.mkstemp(prefix=path.name+".tmp.",dir=path.parent)
 try:
  with os.fdopen(fd,"wb") as f: f.write(data); f.flush(); os.fsync(f.fileno())
  os.replace(tmp,path)
 finally:
  try: os.unlink(tmp)
  except FileNotFoundError: pass
def event(path,kind,**fields):
 with path.open("a",encoding="utf-8") as f: f.write(json.dumps({"at":dt.datetime.now(dt.timezone.utc).isoformat(),"event":kind,**fields},sort_keys=True,separators=(",",":"))+"\n")
def stop(proc):
 if proc is None:return
 try: os.killpg(proc.pid,signal.SIGTERM)
 except ProcessLookupError: pass
 try: proc.wait(timeout=2); return
 except subprocess.TimeoutExpired: pass
 try: os.killpg(proc.pid,signal.SIGKILL)
 except ProcessLookupError: pass
 proc.wait()
def on_signal(_s,_f):
 global INTERRUPTED; INTERRUPTED=True

def abs_file(raw,label,executable=False):
 p=pathlib.Path(raw)
 if not p.is_absolute(): raise ValueError(f"{label} must be absolute")
 p=p.resolve(strict=True)
 if not p.is_file() or p.stat().st_size==0: raise ValueError(f"{label} must be an existing non-empty file")
 if executable and not os.access(p,os.X_OK): raise ValueError(f"{label} must be executable")
 return p
def abs_dir(raw,label):
 p=pathlib.Path(raw)
 if not p.is_absolute(): raise ValueError(f"{label} must be absolute")
 p=p.resolve(strict=True)
 if not p.is_dir(): raise ValueError(f"{label} must be an existing directory")
 return p
def repo_state(repo,excluded):
 cp=subprocess.run(["git","ls-files","-c","-o","--exclude-standard","-z"],cwd=repo,capture_output=True,check=True)
 out={}
 for raw in cp.stdout.split(b"\0"):
  if not raw: continue
  p=repo/os.fsdecode(raw)
  if p==excluded or excluded in p.parents: continue
  st=os.lstat(p); mode=stat.S_IMODE(st.st_mode)
  out[str(p.relative_to(repo))]=("link",mode,os.readlink(p)) if stat.S_ISLNK(st.st_mode) else (("file",mode,c.sha(p)) if stat.S_ISREG(st.st_mode) else ("other",mode))
 return out
def artifact_digests(root,exclude=()):
 return {str(p.relative_to(root)):c.sha(p) for p in sorted(root.rglob("*")) if p.is_file() and p not in exclude}
def verifier_schema():
 return {"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","additionalProperties":False,"required":["finding_id","verdict","evidence","reason"],"properties":{"finding_id":{"type":"string","pattern":"^CX-[0-9]{4}$"},"verdict":{"enum":["closed","not_closed","closure_requires_new_review"]},"evidence":{"type":"array","maxItems":50,"items":{"type":"string","minLength":1,"maxLength":8000}},"reason":{"type":"string","minLength":1,"maxLength":8000}}}
def degraded(msg,evidence=None):
 obj={"schema_version":1,"outcome":"degraded","clean":False,"adapter_converged":False,"error":msg}
 if evidence: obj["evidence_dir"]=str(evidence)
 return emit(obj,11)

def main():
 ap=argparse.ArgumentParser(); ap.add_argument("--repo",required=True); ap.add_argument("--original-plan",required=True); ap.add_argument("--final-plan",required=True); ap.add_argument("--registry",required=True); ap.add_argument("--manifest",required=True); ap.add_argument("--codex",required=True); ap.add_argument("--output-dir",required=True); ap.add_argument("--timeout",type=float,default=600); ap.add_argument("--prior-result")
 a=ap.parse_args()
 try:
  repo=abs_dir(a.repo,"repo"); original=abs_file(a.original_plan,"original plan"); final=abs_file(a.final_plan,"final plan"); registry_path=abs_file(a.registry,"registry"); manifest_path=abs_file(a.manifest,"manifest"); codex=abs_file(a.codex,"codex",True)
  if subprocess.run(["git","rev-parse","--is-inside-work-tree"],cwd=repo,capture_output=True,text=True).stdout.strip()!="true": raise ValueError("repo must be a trusted git worktree")
  if subprocess.run(["git","config","--global","--get-all","safe.directory"],capture_output=True,text=True).returncode==0: pass
  output=pathlib.Path(a.output_dir)
  if not output.is_absolute(): raise ValueError("output dir must be absolute")
  output=output.resolve(strict=False)
  if output.exists(): raise ValueError("output dir must be new")
  parent=output.parent.resolve(strict=True)
  if not parent.is_dir() or not os.access(parent,os.W_OK): raise ValueError("output parent must be writable")
  if a.timeout<=0: raise ValueError("timeout must be positive")
  original_sha=c.sha(original); final_sha=c.sha(final); registry_sha=c.sha(registry_path)
  reg=c.load_json(registry_path); c.validate_registry(reg,repo_root=str(repo),original_sha=original_sha)
  prior=None; prior_sha=None; recheck_ids=None
  if a.prior_result:
   prior_path=abs_file(a.prior_result,"prior result"); prior=c.load_json(prior_path); prior_sha=c.sha(prior_path)
   if prior.get("attempt")!=1 or prior.get("outcome")!="blocked": raise ValueError("recheck requires blocked attempt-1 result")
   if prior.get("final_plan_sha256")!=final_sha or prior.get("registry_sha256")!=registry_sha: raise ValueError("prior result identity mismatch")
   if any(x.get("verdict")=="closure_requires_new_review" for x in prior.get("verifications",[])): raise ValueError("architecture/scope-change outcome cannot recheck")
   recheck_ids={x["finding_id"] for x in prior.get("verifications",[]) if x.get("verdict")=="not_closed"}
   if not recheck_ids: raise ValueError("prior result has no not_closed IDs to recheck")
  man=c.load_json(manifest_path); rows=c.validate_manifest(man,reg,repo_root=str(repo),original_sha=original_sha,final_sha=final_sha,registry_sha=registry_sha,prior_result_sha=prior_sha,recheck_ids=recheck_ids)
 except Exception as exc: return degraded(str(exc))
 try: output.mkdir(mode=0o700)
 except OSError as exc: return degraded(str(exc))
 events=output/"events.jsonl"; artifacts=output/"artifacts"; artifacts.mkdir(); rawdir=output/"verifiers"; rawdir.mkdir()
 copies={"registry.json":registry_path,"original-plan.md":original,"final-plan.md":final,"closure-manifest.json":manifest_path}
 if a.prior_result: copies["prior-result.json"]=pathlib.Path(a.prior_result)
 for name,src in copies.items(): shutil.copyfile(src,artifacts/name)
 schema=output/"closure-output.schema.json"; atom(schema,c.canonical(verifier_schema()).encode())
 baseline=repo_state(repo,output); final_bound=final_sha; started=time.monotonic(); deadline=started+a.timeout; verifications=[]; process_rows=[]; outcome="accepted_after_targeted_closure"; error=None
 finding_byid={x["finding_id"]:x for x in reg["findings"]}
 signal.signal(signal.SIGTERM,on_signal); signal.signal(signal.SIGINT,on_signal)
 global ACTIVE
 for fid,row in rows.items():
  if row["disposition"] not in c.VERIFY_DISPOSITIONS: continue
  remaining=deadline-time.monotonic()
  if remaining<=0 or INTERRUPTED: outcome="timed_out"; error="adapter wall clock expired or was cancelled"; break
  prompt=rawdir/f"{fid}.prompt.txt"; raw=rawdir/f"{fid}.raw.json"
  context={"finding":finding_byid[fid],"original_frozen_plan":(artifacts/"original-plan.md").read_text(),"final_plan":(artifacts/"final-plan.md").read_text(),"changed_sections":row["changed_sections"],"disposition":row["disposition"],"rationale":row["rationale"],"repository_context":{"repo_root":str(repo),"topic":reg["topic"]}}
  text="You are a targeted closure verifier. Check only the exact finding below. Do not perform generic review, propose new findings or IDs, edit the plan, or decide product ownership/risk acceptance. Decide only whether the exact underlying risk is closed without a directly contradictory architecture or scope-contract change. Return only schema JSON.\n"+c.canonical(context)
  atom(prompt,text.encode()); event(events,"verifier_start",finding_id=fid)
  before=repo_state(repo,output)
  with prompt.open("rb") as inp:
   ACTIVE=subprocess.Popen([str(codex),"exec","--sandbox","read-only","--ephemeral","--ignore-rules","--output-schema",str(schema),"--output-last-message",str(raw),"-"],cwd=repo,stdin=inp,stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL,start_new_session=True)
  timed=False
  try: rc=ACTIVE.wait(timeout=max(.01,remaining))
  except subprocess.TimeoutExpired: stop(ACTIVE); rc=124; timed=True
  process_rows.append({"finding_id":fid,"pid":ACTIVE.pid,"exit_code":rc,"timed_out":timed}); ACTIVE=None
  if timed or INTERRUPTED: outcome="timed_out"; error=f"verifier timed out/cancelled for {fid}"; break
  if rc!=0: outcome="degraded"; error=f"reviewer nonzero for {fid}: {rc}"; break
  try:
   if repo_state(repo,output)!=before or repo_state(repo,output)!=baseline: raise ValueError("repository mutation detected")
   if c.sha(final)!=final_bound: raise ValueError("final plan hash mutated")
   obj=c.load_json(raw); c.validate_verifier(obj,fid); verifications.append(obj); event(events,"verifier_complete",finding_id=fid,verdict=obj["verdict"])
   if obj["verdict"]=="closure_requires_new_review": outcome="closure_requires_new_review"
   elif obj["verdict"]=="not_closed" and outcome=="accepted_after_targeted_closure": outcome="blocked"
  except Exception as exc: outcome="degraded"; error=str(exc); break
  if outcome=="closure_requires_new_review": break
 # Revalidate all copied identities and immutable inputs before terminal verdict.
 try:
  if c.sha(final)!=final_bound or repo_state(repo,output)!=baseline: raise ValueError("final/repository mutation at terminal revalidation")
  if c.sha(artifacts/"registry.json")!=registry_sha or c.sha(artifacts/"original-plan.md")!=original_sha or c.sha(artifacts/"final-plan.md")!=final_sha or c.sha(artifacts/"closure-manifest.json")!=c.sha(manifest_path): raise ValueError("copied artifact tamper detected")
  c.validate_registry(c.load_json(artifacts/"registry.json"),repo_root=str(repo),original_sha=original_sha)
  if os.environ.get("CLAUDEX_CLOSURE_TAMPER_HOOK"): (artifacts/"registry.json").write_text("{}\n")
  if c.sha(artifacts/"registry.json")!=registry_sha: raise ValueError("copied artifact tamper detected")
 except Exception as exc: outcome="degraded"; error=str(exc)
 result={"schema_version":1,"engine":"review-v3","review_id":reg["review_id"],"topic":reg["topic"],"attempt":man["attempt"],"outcome":outcome,"clean":outcome=="accepted_after_targeted_closure","adapter_converged":False,"repo_root":str(repo),"original_snapshot_sha256":original_sha,"final_plan_sha256":final_sha,"registry_sha256":registry_sha,"manifest_sha256":c.sha(manifest_path),"prior_result_sha256":prior_sha,"dispositions":list(rows.values()),"verifications":verifications,"processes":process_rows,"elapsed_seconds":round(time.monotonic()-started,6),"evidence_dir":str(output)}
 if error: result["error"]=error
 atom(output/"processes.json",c.canonical(process_rows).encode()); atom(output/"artifact-digests.json",c.canonical(artifact_digests(output,exclude={output/"result.json"})).encode()); atom(output/"result.json",c.canonical(result).encode())
 # Last exact result/artifact digest publication is atomic; stdout is exactly one JSON.
 return emit(result,EXIT[outcome])
if __name__=="__main__": sys.exit(main())
