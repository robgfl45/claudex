#!/usr/bin/env python3
"""Headless Claude Code -> Claudex -> Codex plan review adapter.

Stdout is always one strict JSON document. Human/debug output and subprocess
streams are retained in an evidence directory instead of being mixed into the
machine-readable result.
"""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import time
import uuid
from decimal import Decimal, InvalidOperation
from pathlib import Path
from typing import Any

TERMINAL_PHASES = {"done", "cancelled", "errored"}
ACTIVE_PHASES = {"drafting", "reviewing", "revising", "summarizing"}
EXIT_CODES = {"converged": 0, "findings_returned": 10, "max_reached": 10, "degraded": 11, "failed": 12, "timed_out": 124}
SWEEP_PERSONAS = [
    "architecture-scope",
    "security-data",
    "product-domain",
    "quality-accessibility-performance",
    "operations-deployment",
]
SHA256_RE = re.compile(r"[0-9a-f]{64}")
_PENDING_PLAN_RESTORE: tuple[Path, Path, bool] | None = None
_PENDING_ADAPTER_LOCK: Path | None = None
_INTERRUPTED_SIGNAL: int | None = None


def record_interrupt(signum: int, _frame: Any) -> None:
    """Defer external-signal cleanup to the normal supervision loop."""
    global _INTERRUPTED_SIGNAL
    _INTERRUPTED_SIGNAL = signum


def terminate_process_group(process: subprocess.Popen[bytes], grace_seconds: float = 5) -> None:
    """Idempotently terminate and reap the adapter-owned subprocess session."""
    if process.poll() is not None:
        process.wait()
        return
    try:
        os.killpg(process.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    try:
        process.wait(timeout=grace_seconds)
        return
    except subprocess.TimeoutExpired:
        pass
    try:
        os.killpg(process.pid, signal.SIGKILL)
    except ProcessLookupError:
        pass
    process.wait(timeout=grace_seconds)


def terminate_recorded_reviewer_group(state_dir: Path, selected_state: Path | None, grace_seconds: float = 5) -> None:
    """Terminate the detached Codex group recorded by the sweep runner."""
    if selected_state is None:
        return
    review_id = selected_state.stem
    if not re.fullmatch(r"[0-9]{8}-[0-9]{6}-[0-9a-f]{6}", review_id):
        return
    marker = state_dir / f"{review_id}-active-pgid"
    try:
        raw = marker.read_text(encoding="utf-8").strip()
        pgid = int(raw)
        if pgid <= 1:
            return
    except (FileNotFoundError, OSError, ValueError):
        return

    def group_alive() -> bool:
        try:
            os.killpg(pgid, 0)
            return True
        except ProcessLookupError:
            return False

    try:
        os.killpg(pgid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    deadline = time.monotonic() + grace_seconds
    while group_alive() and time.monotonic() < deadline:
        time.sleep(0.05)
    if group_alive():
        try:
            os.killpg(pgid, signal.SIGKILL)
        except ProcessLookupError:
            pass
    try:
        if marker.read_text(encoding="utf-8").strip() == raw:
            marker.unlink(missing_ok=True)
    except OSError:
        pass


def restore_pending_plan() -> str | None:
    """Best-effort restoration for an externally staged repository PLAN.md."""
    global _PENDING_PLAN_RESTORE
    pending = _PENDING_PLAN_RESTORE
    if pending is None:
        return None
    runtime_plan, original_plan, had_original = pending
    try:
        if had_original:
            shutil.copy2(original_plan, runtime_plan)
        else:
            runtime_plan.unlink(missing_ok=True)
    except OSError as exc:
        return str(exc)
    _PENDING_PLAN_RESTORE = None
    return None


def release_adapter_lock() -> None:
    global _PENDING_ADAPTER_LOCK
    if _PENDING_ADAPTER_LOCK is not None:
        try:
            if _PENDING_ADAPTER_LOCK.read_text(encoding="utf-8").strip() == str(os.getpid()):
                _PENDING_ADAPTER_LOCK.unlink(missing_ok=True)
        except OSError:
            pass
        _PENDING_ADAPTER_LOCK = None


def pid_alive(raw: str) -> bool:
    try:
        os.kill(int(raw.strip()), 0)
        return True
    except (ValueError, OSError):
        return False


def validate_resume_identity(repo: Path, plan: Path, state_dir: Path, review_id: str, topic: str, maximum: int) -> tuple[Path, Path]:
    if not re.fullmatch(r"[0-9]{8}-[0-9]{6}-[0-9a-f]{6}", review_id):
        raise ValueError("--resume-review-id has an invalid format")
    state_file = state_dir / f"{review_id}.state"
    review_dir = state_dir / review_id
    if not state_file.is_file() or not review_dir.is_dir():
        raise ValueError("resume review state/evidence does not exist")
    state, errors = strict_state(state_file)
    expected = {"review_id": review_id, "mode": "plan", "engine": "sweep-v2", "repo_root": str(repo), "topic": topic, "max_generations": str(maximum)}
    for key, value in expected.items():
        if state.get(key) != value:
            errors.append(f"resume {key} does not match the requested immutable identity")
    if plan != (repo / "PLAN.md").resolve(strict=False):
        errors.append("resume requires the canonical repository PLAN.md path")
    if state.get("phase") not in {"reviewing", "awaiting-revision"}:
        errors.append(f"resume phase is not an interrupted active phase: {state.get('phase')}")
    generation_raw = state.get("generation", "")
    generation = int(generation_raw) if generation_raw.isdigit() else 0
    if not 1 <= generation <= maximum:
        errors.append("resume generation is invalid")
    snapshot_hash = state.get("snapshot_sha256", "")
    generation_dir = review_dir / "generations" / str(generation)
    try:
        manifest = json.loads((generation_dir / "manifest.json").read_text(encoding="utf-8"))
        required = {"generation", "snapshot_sha256", "required_persona_ids", "topic", "source_plan_path", "previous_generation_sha256"}
        if not isinstance(manifest, dict) or set(manifest) != required:
            raise ValueError("schema mismatch")
        if manifest.get("generation") != generation or manifest.get("snapshot_sha256") != snapshot_hash:
            raise ValueError("generation/hash mismatch")
        if manifest.get("required_persona_ids") != SWEEP_PERSONAS or manifest.get("topic") != topic:
            raise ValueError("topic/persona mismatch")
        if manifest.get("source_plan_path") != str(plan):
            raise ValueError("source plan path mismatch")
        if sha256_file(generation_dir / "PLAN.md") != snapshot_hash:
            raise ValueError("snapshot bytes mismatch")
        previous_hash: str | None = None
        for index in range(1, generation + 1):
            chain_dir = review_dir / "generations" / str(index)
            chain_manifest = json.loads((chain_dir / "manifest.json").read_text(encoding="utf-8"))
            if not isinstance(chain_manifest, dict) or set(chain_manifest) != required:
                raise ValueError(f"generation {index} schema mismatch")
            chain_hash = chain_manifest.get("snapshot_sha256")
            if chain_manifest.get("generation") != index or chain_manifest.get("previous_generation_sha256") != previous_hash:
                raise ValueError(f"generation {index} linkage mismatch")
            if chain_manifest.get("required_persona_ids") != SWEEP_PERSONAS or chain_manifest.get("topic") != topic or chain_manifest.get("source_plan_path") != str(plan):
                raise ValueError(f"generation {index} identity mismatch")
            if not isinstance(chain_hash, str) or not SHA256_RE.fullmatch(chain_hash) or sha256_file(chain_dir / "PLAN.md") != chain_hash:
                raise ValueError(f"generation {index} snapshot mismatch")
            if previous_hash is not None and chain_hash == previous_hash:
                raise ValueError(f"generation {index} did not revise the plan")
            previous_hash = chain_hash
    except (OSError, UnicodeError, json.JSONDecodeError, ValueError) as exc:
        errors.append(f"resume manifest/snapshot is invalid: {exc}")
    try:
        live_hash = sha256_file(plan)
        if state.get("phase") == "reviewing" and live_hash != snapshot_hash:
            errors.append("live PLAN.md changed while the review was still reviewing")
    except OSError as exc:
        errors.append(f"live PLAN.md is unreadable: {exc}")
    lock_candidates = {
        "lock": state_dir / f"{review_id}.lock",
        "active-pgid": state_dir / f"{review_id}-active-pgid",
        "adapter-lock": state_dir / f"{review_id}.adapter-lock",
    }
    for label, candidate in lock_candidates.items():
        try:
            if candidate.is_file() and pid_alive(candidate.read_text(encoding="utf-8")):
                errors.append(f"resume refused because {label} is active")
        except OSError as exc:
            errors.append(f"resume could not inspect {label}: {exc}")
    if errors:
        raise ValueError("; ".join(errors[:5]))
    return state_file, review_dir


def emit(payload: dict[str, Any], code: int) -> int:
    print(json.dumps(payload, sort_keys=True, separators=(",", ":"), ensure_ascii=False))
    return code


def fail(message: str, *, kind: str = "validation", evidence_dir: Path | None = None) -> int:
    payload: dict[str, Any] = {
        "schema_version": 1,
        "outcome": "failed",
        "clean": False,
        "error": {"kind": kind, "message": message},
    }
    if evidence_dir is not None:
        payload["evidence_dir"] = str(evidence_dir)
    return emit(payload, EXIT_CODES["failed"])


def absolute_existing_dir(value: str, label: str) -> Path:
    path = Path(value)
    if not path.is_absolute():
        raise ValueError(f"{label} must be an absolute path")
    resolved = path.resolve(strict=True)
    if not resolved.is_dir():
        raise ValueError(f"{label} is not a directory: {resolved}")
    return resolved


def absolute_existing_file(value: str, label: str) -> Path:
    path = Path(value)
    if not path.is_absolute():
        raise ValueError(f"{label} must be an absolute path")
    resolved = path.resolve(strict=True)
    if not resolved.is_file():
        raise ValueError(f"{label} is not a file: {resolved}")
    if resolved.stat().st_size == 0:
        raise ValueError(f"{label} must be non-empty: {resolved}")
    return resolved


def executable(value: str, label: str) -> Path:
    path = absolute_existing_file(value, label)
    if not os.access(path, os.X_OK):
        raise ValueError(f"{label} is not executable: {path}")
    return path


def run_probe(argv: list[str], cwd: Path, env: dict[str, str], timeout: float = 20) -> subprocess.CompletedProcess[str]:
    return subprocess.run(argv, cwd=cwd, env=env, text=True, capture_output=True, timeout=timeout, check=False)


def validate_plugin_candidate(path: Path, engine: str) -> tuple[Path | None, list[str]]:
    """Validate one candidate without creating anything beneath it."""
    errors: list[str] = []
    try:
        resolved = path.expanduser().resolve(strict=True)
    except OSError as exc:
        return None, [f"does not exist: {exc}"]
    if not resolved.is_dir():
        return None, ["is not a directory"]
    required = [
        resolved / ".claude-plugin" / "plugin.json",
        resolved / "commands" / "plan.md",
        resolved / "hooks" / "hooks.json",
        resolved / "hooks" / "stop-hook.sh",
        resolved / "scripts" / "state-helpers.sh",
    ]
    if engine in {"sweep-v2", "review-v3"}:
        required += [resolved / "scripts" / "sweep-helpers.sh", resolved / "scripts" / "personas.sh"]
    if engine == "review-v3":
        required += [resolved / "scripts" / "review-v3.py"]
    for item in required:
        if not item.is_file():
            errors.append(f"missing required file {item.relative_to(resolved)}")
        else:
            try:
                if item.stat().st_size == 0:
                    errors.append(f"required file is empty {item.relative_to(resolved)}")
            except OSError as exc:
                errors.append(f"required file is unreadable {item.relative_to(resolved)}: {exc}")
    manifest_path = resolved / ".claude-plugin" / "plugin.json"
    if manifest_path.is_file():
        try:
            manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
            if not isinstance(manifest, dict) or not manifest:
                errors.append("manifest must be a non-empty JSON object")
            elif manifest.get("name") != "claudex":
                errors.append("manifest name must be claudex")
        except (OSError, UnicodeError, json.JSONDecodeError) as exc:
            errors.append(f"manifest is unreadable or invalid JSON: {exc}")
    hooks_path = resolved / "hooks" / "hooks.json"
    if hooks_path.is_file() and hooks_path.stat().st_size:
        try:
            hooks_manifest = json.loads(hooks_path.read_text(encoding="utf-8"))
            stop = hooks_manifest.get("hooks", {}).get("Stop") if isinstance(hooks_manifest, dict) else None
            usable = (
                isinstance(hooks_manifest, dict) and bool(hooks_manifest)
                and isinstance(stop, list) and bool(stop)
                and all(isinstance(group, dict) and isinstance(group.get("hooks"), list) and bool(group["hooks"]) for group in stop)
                and any(
                    isinstance(hook, dict)
                    and hook.get("type") == "command"
                    and hook.get("command") == "${CLAUDE_PLUGIN_ROOT}/hooks/stop-hook.sh"
                    for group in stop for hook in group["hooks"]
                )
            )
            if not usable:
                errors.append("hooks manifest must be a non-empty object with the checked-in usable Stop hooks mapping")
        except (OSError, UnicodeError, json.JSONDecodeError) as exc:
            errors.append(f"hooks manifest is unreadable or invalid JSON: {exc}")
    stop_hook = resolved / "hooks" / "stop-hook.sh"
    if stop_hook.is_file() and stop_hook.stat().st_size and not os.access(stop_hook, os.X_OK):
        errors.append("directly executed hooks/stop-hook.sh is not executable")
    return (resolved if not errors else None), errors


def resolve_plugin(explicit: str | None, repo: Path, engine: str) -> tuple[Path, str, list[dict[str, Any]]]:
    adapter = Path(__file__).resolve().parents[1] / "plugins" / "claudex"
    env_value = os.environ.get("CLAUDEX_PLUGIN_ROOT")
    if explicit is not None:
        if not Path(explicit).is_absolute():
            raise ValueError("--plugin-root must be an absolute path")
        candidates = [("explicit", Path(explicit))]
        fail_closed = True
    elif env_value:
        if not Path(env_value).is_absolute():
            raise ValueError("CLAUDEX_PLUGIN_ROOT must be an absolute path")
        candidates = [("environment", Path(env_value))]
        fail_closed = True
    else:
        candidates = [
            ("adapter-relative", adapter),
            ("project-local", repo / ".claude" / "plugins" / "claudex"),
        ]
        # This is intentionally the only installed-layout heuristic: a user-managed
        # Claude plugin at ~/.claude/plugins/claudex. Cache/version layouts are not guessed.
        installed = Path.home() / ".claude" / "plugins" / "claudex"
        if installed.exists():
            candidates.append(("installed-user-plugin", installed))
        fail_closed = False
    diagnostics: list[dict[str, Any]] = []
    valid: list[tuple[str, Path]] = []
    for source, candidate in candidates:
        resolved, errors = validate_plugin_candidate(candidate, engine)
        diagnostics.append({"source": source, "path": str(candidate), "valid": resolved is not None, "resolved_path": str(resolved) if resolved else None, "errors": errors})
        if resolved:
            valid.append((source, resolved))
    if fail_closed and not valid:
        detail = "; ".join(diagnostics[0]["errors"])
        raise ValueError(f"invalid Claudex plugin candidate from {candidates[0][0]} ({candidates[0][1]}): {detail}")
    distinct = {str(path): (source, path) for source, path in valid}
    if not distinct:
        checked = ", ".join(f"{item['source']}={item['path']}" for item in diagnostics)
        raise ValueError(f"no valid Claudex plugin candidate; checked: {checked}")
    if len(distinct) > 1:
        choices = ", ".join(f"{source}={path}" for source, path in valid)
        raise ValueError(f"ambiguous Claudex plugin candidates: {choices}; use --plugin-root to select one")
    selected_path = next(iter(distinct.values()))[1]
    selected_source = next(source for source, path in valid if path == selected_path)
    return selected_path, selected_source, diagnostics


def validate_output_parent(requested: Path) -> Path:
    if not requested.is_absolute():
        raise ValueError("--output-dir must be an absolute path")
    current = requested
    while not current.exists() and current != current.parent:
        current = current.parent
    if not current.is_dir():
        raise ValueError(f"nearest existing output parent is not a directory: {current}")
    mode = current.stat().st_mode
    if mode & 0o222 == 0 or not os.access(current, os.W_OK | os.X_OK):
        raise ValueError(f"nearest existing output parent is not writable: {current}")
    return current


def decode_state_value(key: str, value: str) -> str:
    parsed = value.strip()
    if key == "topic" and len(parsed) >= 2 and parsed.startswith('"') and parsed.endswith('"'):
        try:
            decoded = json.loads(parsed)
            if isinstance(decoded, str):
                return decoded
        except json.JSONDecodeError:
            return parsed[1:-1].replace('\\"', '"')
    return parsed


def parse_state(path: Path) -> dict[str, str]:
    result: dict[str, str] = {}
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            if ":" not in line:
                continue
            key, value = line.split(":", 1)
            if re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", key):
                result[key] = decode_state_value(key, value)
    except OSError:
        pass
    return result


def snapshot_state(state_file: Path, events, last: dict[str, str] | None) -> dict[str, str] | None:
    if not state_file.exists():
        return last
    current = parse_state(state_file)
    if current != last:
        events.write(json.dumps({"at": dt.datetime.now(dt.timezone.utc).isoformat(), "state": current}, sort_keys=True) + "\n")
        events.flush()
    return current


def final_findings_status(path: Path | None) -> tuple[str, dict[str, int]]:
    counts = {"high": 0, "medium": 0, "low": 0}
    if path is None or not path.is_file():
        return "missing", counts
    text = path.read_text(encoding="utf-8", errors="replace")
    section = ""
    for line in text.splitlines():
        if line.startswith("## High"):
            section = "high"
        elif line.startswith("## Medium"):
            section = "medium"
        elif line.startswith("## Low"):
            section = "low"
        elif line.startswith("## "):
            section = ""
        elif line.startswith("- ") and section:
            counts[section] += 1
    no_findings = bool(re.search(r"(?mi)^No substantive findings\.\s*$", text))
    if no_findings and not any(counts.values()):
        return "none", counts
    if any(counts.values()):
        return "material", counts
    return "unparseable", counts


def sha256_file(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def strict_state(path: Path) -> tuple[dict[str, str], list[str]]:
    state: dict[str, str] = {}
    errors: list[str] = []
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except (OSError, UnicodeError) as exc:
        return {}, [f"state is unreadable: {exc}"]
    for number, line in enumerate(lines, 1):
        if ":" not in line:
            errors.append(f"state line {number} is malformed")
            continue
        key, value = line.split(":", 1)
        if not re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", key):
            errors.append(f"state line {number} has an invalid key")
        elif key in state:
            errors.append(f"state contains duplicate field {key}")
        else:
            state[key] = decode_state_value(key, value)
    return state, errors


def sweep_findings(path: Path) -> tuple[str, dict[str, int]]:
    counts = {"high": 0, "medium": 0, "low": 0}
    try:
        text = path.read_text(encoding="utf-8")
    except (OSError, UnicodeError):
        return "malformed", counts
    if text.strip() == "No substantive findings.":
        return "clean", counts
    lines = [line.rstrip() for line in text.splitlines() if line.strip()]
    headers = ["## High", "## Medium", "## Low"]
    if any(lines.count(header) != 1 for header in headers):
        return "malformed", counts
    positions = [lines.index(header) for header in headers]
    if positions != sorted(positions) or lines[: positions[0]]:
        return "malformed", counts
    for index, start in enumerate(positions):
        end = positions[index + 1] if index + 1 < len(positions) else len(lines)
        severity = headers[index][3:].lower()
        for line in lines[start + 1 : end]:
            if not line.startswith("- ") or len(line) <= 2:
                return "malformed", counts
            counts[severity] += 1
    return ("material" if any(counts.values()) else "malformed"), counts


def render_sweep_findings(path: Path, persona: str) -> str:
    severity = ""
    counts = {"high": 0, "medium": 0, "low": 0}
    rendered: list[str] = []
    for line in path.read_text(encoding="utf-8").splitlines():
        if line in {"## High", "## Medium", "## Low"}:
            severity = line[3:].lower()
            rendered.append(line)
        elif line.startswith("- ") and severity:
            counts[severity] += 1
            rendered.append(f"- [{persona}-{severity}-{counts[severity]}] {line[2:]}")
        else:
            rendered.append(line)
    return "\n".join(rendered)


def validate_sweep(state_file: Path, review_dir: Path, source_review_dir: Path, runtime_plan: Path, reviewed_plan: Path, requested: int, requested_topic: str) -> dict[str, Any]:
    """Recompute a sweep verdict from runner-authored state and artifacts."""
    state, errors = strict_state(state_file)
    coverage: list[dict[str, Any]] = []
    severity = {"high": 0, "medium": 0, "low": 0}

    def integer(name: str) -> int | None:
        value = state.get(name, "")
        return int(value) if value.isdigit() else None

    generation = integer("generation")
    maximum = integer("max_generations")
    expected_review_id = state_file.stem
    if state.get("review_id") != expected_review_id or review_dir.name != expected_review_id or source_review_dir.name != expected_review_id:
        errors.append("state filename, review_id, and review evidence directory do not match")
    if state.get("mode") != "plan":
        errors.append("state mode is not plan")
    if state.get("repo_root") != str(runtime_plan.parent):
        errors.append("state repo_root does not match the reviewed repository")
    if not state.get("topic"):
        errors.append("state topic is empty")
    elif state.get("topic") != requested_topic:
        errors.append("state topic does not match the requested topic")
    if state.get("engine") != "sweep-v2":
        errors.append("state engine is not sweep-v2")
    if generation is None or not 1 <= generation <= 5:
        errors.append("state generation is not in 1..5")
    if maximum is None or not 1 <= maximum <= 5:
        errors.append("state max_generations is not in 1..5")
    elif maximum != requested:
        errors.append("state max_generations does not match the requested cap")
    if generation and maximum and generation > maximum:
        errors.append("state generation exceeds max_generations")

    generation_dir = review_dir / "generations" / str(generation) if generation else None
    snapshot = generation_dir / "PLAN.md" if generation_dir else None
    manifest_path = generation_dir / "manifest.json" if generation_dir else None
    consolidated = generation_dir / "consolidated-findings.md" if generation_dir else None
    snapshot_hash = state.get("snapshot_sha256", "")
    if not SHA256_RE.fullmatch(snapshot_hash):
        errors.append("state snapshot_sha256 is malformed")
    if state.get("reviewed_live_sha256") != snapshot_hash:
        errors.append("state reviewed_live_sha256 does not match the current snapshot")

    manifest: dict[str, Any] = {}
    manifest_loaded = False
    if manifest_path:
        try:
            manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
            if not isinstance(manifest, dict):
                raise ValueError("manifest is not an object")
            manifest_loaded = True
        except (OSError, UnicodeError, json.JSONDecodeError, ValueError) as exc:
            errors.append(f"generation manifest is unreadable or malformed: {exc}")
    if manifest_loaded:
        required = {"generation", "snapshot_sha256", "required_persona_ids", "topic", "source_plan_path", "previous_generation_sha256"}
        if set(manifest) != required:
            errors.append("generation manifest fields do not match the sweep-v2 schema")
        if manifest.get("generation") != generation or manifest.get("snapshot_sha256") != snapshot_hash:
            errors.append("generation manifest does not match state generation/hash")
        if manifest.get("required_persona_ids") != SWEEP_PERSONAS:
            errors.append("generation manifest does not require the exact five personas")
        if not isinstance(manifest.get("topic"), str) or not manifest.get("topic"):
            errors.append("generation manifest topic is empty")
        elif manifest.get("topic") != state.get("topic"):
            errors.append("generation manifest topic does not match state")
        if manifest.get("source_plan_path") != str(runtime_plan):
            errors.append("generation manifest source plan path is mismatched")

    # Validate the complete immutable snapshot chain, not only the immediate
    # predecessor. This prevents a terminal generation from hiding a missing,
    # malformed, or unchanged earlier generation.
    if generation:
        chain_previous: str | None = None
        required_manifest_fields = {"generation", "snapshot_sha256", "required_persona_ids", "topic", "source_plan_path", "previous_generation_sha256"}
        for index in range(1, generation + 1):
            chain_dir = review_dir / "generations" / str(index)
            try:
                chain_manifest = json.loads((chain_dir / "manifest.json").read_text(encoding="utf-8"))
                if not isinstance(chain_manifest, dict) or set(chain_manifest) != required_manifest_fields:
                    raise ValueError("manifest schema mismatch")
                chain_hash = chain_manifest.get("snapshot_sha256")
                if chain_manifest.get("generation") != index:
                    raise ValueError("generation number mismatch")
                if chain_manifest.get("required_persona_ids") != SWEEP_PERSONAS:
                    raise ValueError("persona set mismatch")
                if chain_manifest.get("topic") != requested_topic:
                    raise ValueError("topic mismatch")
                if chain_manifest.get("source_plan_path") != str(runtime_plan):
                    raise ValueError("source path mismatch")
                if not isinstance(chain_hash, str) or not SHA256_RE.fullmatch(chain_hash):
                    raise ValueError("snapshot hash is malformed")
                if chain_manifest.get("previous_generation_sha256") != chain_previous:
                    raise ValueError("previous hash linkage mismatch")
                if chain_previous is not None and chain_hash == chain_previous:
                    raise ValueError("generation snapshot did not change")
                if sha256_file(chain_dir / "PLAN.md") != chain_hash:
                    raise ValueError("snapshot bytes do not match manifest")
                chain_previous = chain_hash
            except (OSError, UnicodeError, json.JSONDecodeError, TypeError, ValueError) as exc:
                errors.append(f"generation {index} manifest/snapshot chain is invalid: {exc}")
                break

    try:
        if not snapshot or sha256_file(snapshot) != snapshot_hash:
            errors.append("frozen snapshot hash does not match state")
    except OSError as exc:
        errors.append(f"frozen snapshot is unreadable: {exc}")
    try:
        if sha256_file(reviewed_plan) != snapshot_hash:
            errors.append("reviewed live PLAN.md is not the frozen snapshot")
    except OSError as exc:
        errors.append(f"reviewed live PLAN.md is unreadable: {exc}")

    evidence_digest = hashlib.sha256()
    chunks = [f"# Consolidated findings — generation {generation}\n\n", f"Snapshot SHA-256: `{snapshot_hash}`\n\n"]
    if generation_dir:
        for persona in SWEEP_PERSONAS:
            findings = generation_dir / f"{persona}.findings.md"
            sidecar = generation_dir / f"{persona}.result.json"
            classification, counts = sweep_findings(findings)
            entry: dict[str, Any] = {
                "persona_id": persona,
                "classification": classification,
                "snapshot_sha256": None,
                "valid": False,
            }
            for key in severity:
                severity[key] += counts[key]
            sidecar_data: dict[str, Any] = {}
            try:
                sidecar_data = json.loads(sidecar.read_text(encoding="utf-8"))
                if not isinstance(sidecar_data, dict):
                    raise ValueError("sidecar is not an object")
            except (OSError, UnicodeError, json.JSONDecodeError, ValueError) as exc:
                errors.append(f"{persona} sidecar is unreadable or malformed: {exc}")
            if sidecar_data:
                required = {"persona_id", "expected_snapshot_sha256", "actual_snapshot_sha256_before", "actual_snapshot_sha256_after", "codex_exit_code", "findings_path", "findings_sha256", "findings_classification", "completed_at"}
                expected_path = source_review_dir / "generations" / str(generation) / findings.name
                reported_path_value = sidecar_data.get("findings_path")
                reported_path = Path(reported_path_value) if isinstance(reported_path_value, str) else None
                if reported_path is not None and not reported_path.is_absolute():
                    reported_path = runtime_plan.parent / reported_path
                valid = set(sidecar_data) == required
                valid &= sidecar_data.get("persona_id") == persona
                valid &= sidecar_data.get("expected_snapshot_sha256") == snapshot_hash
                valid &= sidecar_data.get("actual_snapshot_sha256_before") == snapshot_hash
                valid &= sidecar_data.get("actual_snapshot_sha256_after") == snapshot_hash
                valid &= sidecar_data.get("codex_exit_code") == 0
                valid &= reported_path is not None and reported_path.resolve() == expected_path.resolve()
                valid &= sidecar_data.get("findings_classification") == classification
                try:
                    valid &= sidecar_data.get("findings_sha256") == sha256_file(findings)
                except OSError:
                    valid = False
                try:
                    dt.datetime.strptime(str(sidecar_data.get("completed_at")), "%Y-%m-%dT%H:%M:%SZ")
                except (TypeError, ValueError):
                    valid = False
                if not valid or classification not in {"clean", "material"}:
                    errors.append(f"{persona} evidence is incomplete, hash-mismatched, or malformed")
                else:
                    entry.update(snapshot_sha256=snapshot_hash, valid=True)
            coverage.append(entry)
            chunks.append(f"## {persona}\n\n")
            if classification == "clean":
                chunks.append(findings.read_text(encoding="utf-8") + "\n\n")
            elif classification == "material":
                chunks.append(render_sweep_findings(findings, persona) + "\n\n\n")
            else:
                chunks.append("DEGRADED: invalid evidence.\n\n")
            for artifact in (findings, sidecar):
                try:
                    evidence_digest.update(artifact.name.encode("utf-8") + b"\0")
                    evidence_digest.update(artifact.read_bytes())
                    evidence_digest.update(b"\0")
                except OSError:
                    pass

    consolidated_hash = ""
    try:
        consolidated_text = consolidated.read_text(encoding="utf-8") if consolidated else ""
        consolidated_hash = sha256_file(consolidated) if consolidated else ""
        if consolidated_text != "".join(chunks):
            errors.append("consolidated findings do not exactly match persona evidence")
    except (OSError, UnicodeError) as exc:
        errors.append(f"consolidated findings are unreadable: {exc}")
    if state.get("evidence_sha256") != evidence_digest.hexdigest():
        errors.append("state evidence_sha256 does not match generation evidence")
    if state.get("consolidated_sha256") != consolidated_hash:
        errors.append("state consolidated_sha256 does not match consolidated findings")

    all_clean = len(coverage) == 5 and all(item["valid"] and item["classification"] == "clean" for item in coverage)
    any_material = any(item["valid"] and item["classification"] == "material" for item in coverage)
    phase, signal = state.get("phase"), state.get("decision_signal")
    if not errors and phase == "done" and signal == "converged" and state.get("clean") == "true" and state.get("coverage_complete") == "true" and all_clean and state.get("converged_snapshot_sha256") == snapshot_hash:
        outcome = "converged"
        reason = "terminal sweep-v2 state and complete same-snapshot five-persona evidence prove convergence"
    elif not errors and phase == "done" and signal == "max-reached" and state.get("clean") == "false" and state.get("coverage_complete") == "true" and generation == maximum and any_material and not all_clean and not state.get("converged_snapshot_sha256"):
        outcome = "max_reached"
        reason = "sweep-v2 reached its generation cap with authoritative material findings"
    else:
        outcome = "degraded"
        mismatch = errors or [f"terminal/state verdict mismatch (phase={phase}, signal={signal}, clean={state.get('clean')}, coverage={state.get('coverage_complete')})"]
        reason = "sweep-v2 evidence is incomplete or inconsistent: " + "; ".join(mismatch[:4])
    return {
        "outcome": outcome, "reason": reason, "state": state,
        "generation": generation, "max_generations": maximum,
        "snapshot_sha256": snapshot_hash or None,
        "converged_snapshot_sha256": state.get("converged_snapshot_sha256") or None,
        "persona_coverage": coverage, "severity_counts": severity,
        "findings_status": "none" if all_clean else ("material" if any_material else "malformed"),
        "generation_dir": generation_dir, "manifest": manifest_path,
        "consolidated": consolidated, "errors": errors,
    }


def validate_review_v3(state_file: Path, review_dir: Path, runtime_plan: Path, topic: str) -> dict[str, Any]:
    state, errors = strict_state(state_file)
    gen = review_dir / "generations" / "1"
    sha = state.get("snapshot_sha256", "")
    registry_path, consolidated_path = gen / "findings-registry.json", gen / "consolidated-findings.md"
    coverage=[]; counts={"high":0,"medium":0,"low":0}; registry={}
    try:
        manifest=json.loads((gen/"manifest.json").read_text())
        required={"schema_version","review_id","engine","generation","snapshot_sha256","required_persona_ids","topic","repo_root","source_plan_path"}
        if set(manifest)!=required or manifest.get("review_id")!=state_file.stem or manifest.get("engine")!="review-v3" or manifest.get("required_persona_ids")!=SWEEP_PERSONAS or manifest.get("topic")!=topic or manifest.get("repo_root")!=str(runtime_plan.parent) or manifest.get("source_plan_path")!=str(runtime_plan) or manifest.get("snapshot_sha256")!=sha: errors.append("review-v3 manifest identity mismatch")
        if sha256_file(gen/"PLAN.md")!=sha or sha256_file(runtime_plan)!=sha: errors.append("review-v3 frozen/live plan mutation")
        registry=json.loads(registry_path.read_text())
        if set(registry)!={"schema_version","review_id","engine","snapshot_sha256","topic","repo_root","source_plan_path","persona_order","findings"} or registry.get("review_id")!=state_file.stem or registry.get("engine")!="review-v3" or registry.get("snapshot_sha256")!=sha or registry.get("topic")!=topic or registry.get("persona_order")!=SWEEP_PERSONAS: errors.append("review-v3 registry identity mismatch")
        expected_ids=[f"CX-{i:04d}" for i in range(1,len(registry.get("findings",[]))+1)]
        if [f.get("finding_id") for f in registry.get("findings",[])]!=expected_ids: errors.append("review-v3 registry IDs are duplicate, unknown, or unstable")
        for f in registry.get("findings",[]): counts[f["severity"]]+=1
        helper=Path(__file__).resolve().parents[1]/"plugins"/"claudex"/"scripts"/"review-v3.py"
        namespace={}; exec(compile(helper.read_text(),str(helper),"exec"),namespace)
        if consolidated_path.read_text()!=namespace["render"](registry): errors.append("review-v3 consolidated output mismatch")
        if state.get("registry_sha256")!=sha256_file(registry_path) or state.get("consolidated_sha256")!=sha256_file(consolidated_path): errors.append("review-v3 digest mismatch")
    except Exception as exc: errors.append(f"review-v3 evidence malformed: {exc}")
    for persona in SWEEP_PERSONAS:
        valid=False
        try:
            raw=gen/f"{persona}.raw.json"; side=gen/f"{persona}.result.json"; obj=json.loads(raw.read_text()); sc=json.loads(side.read_text())
            namespace["validate"](obj,persona,sha)
            valid=set(sc)=={"persona_id","snapshot_sha256","raw_path","raw_sha256","codex_exit_code","valid","error","completed_at"} and sc["persona_id"]==persona and sc["snapshot_sha256"]==sha and sc["raw_sha256"]==sha256_file(raw) and sc["codex_exit_code"]==0 and sc["valid"] is True and sc["error"] is None
        except Exception as exc: errors.append(f"{persona} structured evidence invalid: {exc}")
        coverage.append({"persona_id":persona,"snapshot_sha256":sha if valid else None,"valid":valid,"classification":obj.get("classification") if valid else "malformed"})
    material=bool(registry.get("findings",[]))
    expected_signal="findings-returned" if material else "converged"
    terminal=state.get("phase")=="done" and state.get("coverage_complete")=="true" and state.get("decision_signal")==expected_signal and state.get("clean")==str(not material).lower()
    outcome=("findings_returned" if material else "converged") if not errors and terminal and all(x["valid"] for x in coverage) else "degraded"
    return {"outcome":outcome,"reason":"validated review-v3 registry and exact five-persona same-hash evidence" if outcome!="degraded" else "review-v3 evidence incomplete or inconsistent: "+"; ".join(errors[:4]),"state":state,"generation":1,"max_generations":1,"snapshot_sha256":sha,"converged_snapshot_sha256":sha if outcome=="converged" else None,"persona_coverage":coverage,"severity_counts":counts,"findings_status":"material" if material else "none","generation_dir":gen,"manifest":gen/"manifest.json","consolidated":consolidated_path,"registry":registry_path,"errors":errors}


def parse_claude_stream(path: Path) -> dict[str, Any]:
    summary: dict[str, Any] = {"result_records": 0, "reported_cost_usd": None, "session_id": None}
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if obj.get("type") == "result":
                summary["result_records"] += 1
                summary["reported_cost_usd"] = obj.get("total_cost_usd", obj.get("cost_usd"))
                summary["session_id"] = obj.get("session_id")
                summary["claude_result_subtype"] = obj.get("subtype")
    except OSError:
        pass
    return summary


def copy_if_exists(source: Path, destination: Path) -> None:
    if source.exists():
        if source.is_dir():
            shutil.copytree(source, destination, dirs_exist_ok=True)
        else:
            destination.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(source, destination)


class JsonArgumentParser(argparse.ArgumentParser):
    def error(self, message: str) -> None:
        payload = {
            "schema_version": 1,
            "outcome": "failed",
            "clean": False,
            "error": {"kind": "arguments", "message": message},
        }
        print(json.dumps(payload, sort_keys=True, separators=(",", ":")))
        raise SystemExit(EXIT_CODES["failed"])


def main() -> int:
    global _PENDING_PLAN_RESTORE, _PENDING_ADAPTER_LOCK
    parser = JsonArgumentParser(description="Run a bounded headless Claudex review of an existing plan")
    parser.add_argument("--repo", required=True, help="absolute repository path")
    parser.add_argument("--plan", required=True, help="absolute path to an existing non-empty PLAN.md")
    parser.add_argument("--topic", required=True, help="self-contained review topic and constraints")
    parser.add_argument("--rounds", required=True, type=int, help="positive Claudex round limit")
    parser.add_argument("--engine", choices=("review-v3", "sweep-v2", "legacy"), default="sweep-v2", help="plan-review engine (default: sweep-v2)")
    parser.add_argument("--resume-review-id", help="resume one interrupted sweep-v2 review ID")
    parser.add_argument("--timeout", required=True, type=float, help="wall-clock timeout in seconds")
    parser.add_argument("--budget-usd", required=True, help="positive Claude Code budget cap")
    parser.add_argument("--plugin-root", help="absolute Claudex plugin root (normally auto-discovered)")
    parser.add_argument("--claude", required=True, help="absolute Claude Code executable")
    parser.add_argument("--codex", required=True, help="absolute Codex executable")
    parser.add_argument("--output-dir", help="absolute evidence directory (must not already exist)")
    parser.add_argument("--model", default="sonnet", help="Claude model passed to headless Claude Code")
    parser.add_argument("--preflight-only", action="store_true", help="validate prerequisites and emit JSON without starting a review")
    args = parser.parse_args()

    try:
        repo = absolute_existing_dir(args.repo, "--repo")
        if not (repo / ".git").exists():
            raise ValueError(f"--repo must be a git working tree: {repo}")
        plan = absolute_existing_file(args.plan, "--plan")
        plugin, plugin_source, plugin_candidates = resolve_plugin(args.plugin_root, repo, args.engine)
        claude = executable(args.claude, "--claude")
        codex = executable(args.codex, "--codex")
        if args.rounds < 1:
            raise ValueError("--rounds must be a positive integer")
        if args.engine == "sweep-v2" and args.rounds > 5:
            raise ValueError("sweep-v2 --rounds must be in 1..5 generations")
        if args.engine == "review-v3" and args.rounds != 1:
            raise ValueError("review-v3 requires --rounds 1")
        if args.resume_review_id and args.engine != "sweep-v2":
            raise ValueError("--resume-review-id is supported only with --engine sweep-v2")
        if args.timeout <= 0:
            raise ValueError("--timeout must be positive")
        if not args.topic.strip():
            raise ValueError("--topic must be non-empty")
        try:
            budget = Decimal(args.budget_usd)
        except InvalidOperation as exc:
            raise ValueError("--budget-usd must be a positive decimal") from exc
        if not budget.is_finite() or budget <= 0:
            raise ValueError("--budget-usd must be a positive decimal")
        if args.output_dir:
            output_request = Path(args.output_dir)
        else:
            output_request = repo / ".claude" / "claudex" / "adapter-runs" / "preflight-placeholder"
        output_parent = validate_output_parent(output_request)
    except (ValueError, OSError) as exc:
        return fail(str(exc))

    env = os.environ.copy()
    pinned_path = os.pathsep.join(dict.fromkeys([str(claude.parent), str(codex.parent), "/usr/bin", "/bin", "/usr/sbin", "/sbin"]))
    env["PATH"] = pinned_path
    preflight: dict[str, Any] = {
        "pinned_path": pinned_path, "plugin_root": str(plugin), "plugin_source": plugin_source,
        "plugin_candidates": plugin_candidates, "output_parent": str(output_parent),
        "engine": args.engine, "rounds": args.rounds,
    }

    stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    evidence = Path(args.output_dir) if args.output_dir else repo / ".claude" / "claudex" / "adapter-runs" / f"{stamp}-{uuid.uuid4().hex[:8]}"
    if evidence.exists():
        return fail(f"evidence directory already exists: {evidence}")

    def persist_probe_failure(message: str, kind: str) -> int:
        if args.preflight_only:
            return fail(message, kind=kind)
        try:
            evidence.mkdir(parents=True)
            (evidence / "preflight.json").write_text(json.dumps(preflight, indent=2, sort_keys=True) + "\n")
        except OSError as exc:
            message += f"; preflight evidence write failed: {exc}"
        return fail(message, kind=kind, evidence_dir=evidence)

    probe_timeout = 20.0
    test_timeout = os.environ.get("CLAUDEX_TEST_PROBE_TIMEOUT")
    if test_timeout:
        try:
            probe_timeout = max(0.01, min(20.0, float(test_timeout)))
        except ValueError:
            return persist_probe_failure("invalid internal probe timeout", "prerequisite")

    probes: dict[str, subprocess.CompletedProcess[str]] = {}
    probe_commands = (
        ("claude_version", [str(claude), "--version"]),
        ("codex_version", [str(codex), "--version"]),
        ("claude_auth", [str(claude), "auth", "status"]),
        ("codex_auth", [str(codex), "login", "status"]),
    )
    for name, command in probe_commands:
        try:
            completed = run_probe(command, repo, env, timeout=probe_timeout)
        except (OSError, subprocess.TimeoutExpired) as exc:
            preflight[name] = {"error": f"{type(exc).__name__}: {exc}"}
            return persist_probe_failure(f"prerequisite probe failed ({name}): {exc}", "prerequisite")
        probes[name] = completed
        preflight[name] = {
            "path": command[0], "returncode": completed.returncode,
            "stdout": completed.stdout.strip(), "stderr": completed.stderr.strip(),
        }

    claude_version = probes["claude_version"]
    codex_version = probes["codex_version"]
    claude_auth = probes["claude_auth"]
    codex_auth = probes["codex_auth"]
    if claude_version.returncode != 0 or codex_version.returncode != 0:
        return persist_probe_failure("Claude or Codex version probe failed", "prerequisite")
    try:
        auth_obj = json.loads(claude_auth.stdout)
    except json.JSONDecodeError:
        auth_obj = {}
    if claude_auth.returncode != 0 or auth_obj.get("loggedIn") is not True:
        return persist_probe_failure("Claude Code authentication is not active", "authentication")
    codex_auth_text = (codex_auth.stdout + "\n" + codex_auth.stderr).strip()
    codex_positive = {"Logged in using ChatGPT"}
    if codex_auth.returncode != 0 or codex_auth_text not in codex_positive:
        return persist_probe_failure("Codex authentication is not active", "authentication")
    if args.preflight_only:
        return emit({"schema_version": 1, "outcome": "preflight_ok", "clean": True, "preflight": preflight}, 0)

    state_dir = repo / ".claude" / "claudex"
    state_dir.mkdir(parents=True, exist_ok=True)
    resume_state: Path | None = None
    if args.resume_review_id:
        try:
            resume_state, _ = validate_resume_identity(repo, plan, state_dir, args.resume_review_id, args.topic.strip(), args.rounds)
            adapter_lock = state_dir / f"{args.resume_review_id}.adapter-lock"
            if adapter_lock.exists() and not pid_alive(adapter_lock.read_text(encoding="utf-8", errors="replace")):
                adapter_lock.unlink()
            fd = os.open(adapter_lock, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
            with os.fdopen(fd, "w", encoding="utf-8") as handle:
                handle.write(f"{os.getpid()}\n")
            _PENDING_ADAPTER_LOCK = adapter_lock
        except (ValueError, OSError) as exc:
            return fail(str(exc), kind="resume_validation")
    baseline_states = set(state_dir.glob("*.state"))
    for state_file in baseline_states:
        if resume_state is not None and state_file == resume_state:
            continue
        phase = parse_state(state_file).get("phase", "")
        if phase in ACTIVE_PHASES or (phase and phase not in TERMINAL_PHASES):
            return fail(f"active Claudex loop already exists: {state_file} (phase={phase})", kind="active_loop")

    try:
        evidence.mkdir(parents=True)
        (evidence / "preflight.json").write_text(json.dumps(preflight, indent=2, sort_keys=True) + "\n")
    except OSError as exc:
        return fail(f"could not create normal-run evidence: {exc}")
    env["CLAUDEX_ADAPTER_EVIDENCE_DIR"] = str(evidence)

    runtime_plan = repo / "PLAN.md"
    external_plan = plan != runtime_plan.resolve(strict=False)
    original_runtime_plan = evidence / "repo-PLAN.original.md"
    if external_plan and runtime_plan.exists():
        shutil.copy2(runtime_plan, original_runtime_plan)
    shutil.copy2(plan, evidence / "PLAN.before.md")
    if external_plan:
        _PENDING_PLAN_RESTORE = (runtime_plan, original_runtime_plan, original_runtime_plan.exists())
        shutil.copy2(plan, runtime_plan)

    engine_flag = f"--engine {args.engine} " if args.engine != "legacy" else ""
    resume_flag = f"--resume-review-id {args.resume_review_id} " if args.resume_review_id else "--from-draft "
    prompt = f"/claudex:plan {engine_flag}{resume_flag}--skip-interview --rounds {args.rounds} {args.topic.strip()}"
    command = [
        str(claude), "--print", "--verbose", "--output-format", "stream-json", "--include-hook-events",
        "--dangerously-skip-permissions", "--setting-sources", "project", "--plugin-dir", str(plugin),
        "--model", args.model, "--max-budget-usd", str(budget), prompt,
    ]
    metadata = {
        "argv": command, "cwd": str(repo), "timeout_seconds": args.timeout,
        "budget_usd": str(budget), "engine": args.engine, "rounds": args.rounds, "topic": args.topic,
        "resume_review_id": args.resume_review_id,
        "started_at": dt.datetime.now(dt.timezone.utc).isoformat(),
    }
    (evidence / "run-metadata.json").write_text(json.dumps(metadata, indent=2, sort_keys=True) + "\n")

    stdout_path = evidence / "claude-stream.jsonl"
    stderr_path = evidence / "claude-stderr.log"
    events_path = evidence / "state-events.jsonl"
    global _INTERRUPTED_SIGNAL
    _INTERRUPTED_SIGNAL = None
    previous_signal_handlers = {
        signal.SIGTERM: signal.getsignal(signal.SIGTERM),
        signal.SIGINT: signal.getsignal(signal.SIGINT),
    }
    signal.signal(signal.SIGTERM, record_interrupt)
    signal.signal(signal.SIGINT, record_interrupt)
    started = time.monotonic()
    timed_out = False
    externally_interrupted = False
    process: subprocess.Popen[bytes] | None = None
    selected_state: Path | None = resume_state
    last_state: dict[str, str] | None = parse_state(resume_state) if resume_state else None
    try:
        with stdout_path.open("wb") as stdout, stderr_path.open("wb") as stderr, events_path.open("w", encoding="utf-8") as events:
            process = subprocess.Popen(command, cwd=repo, env=env, stdout=stdout, stderr=stderr, start_new_session=True)
            while process.poll() is None:
                new_states = ([resume_state] if resume_state else [path for path in state_dir.glob("*.state") if path not in baseline_states])
                if new_states:
                    selected_state = max(new_states, key=lambda path: path.stat().st_mtime_ns)
                    last_state = snapshot_state(selected_state, events, last_state)
                if _INTERRUPTED_SIGNAL is not None:
                    externally_interrupted = True
                    terminate_process_group(process)
                    terminate_recorded_reviewer_group(state_dir, selected_state)
                    break
                if time.monotonic() - started >= args.timeout:
                    timed_out = True
                    terminate_process_group(process)
                    terminate_recorded_reviewer_group(state_dir, selected_state)
                    break
                time.sleep(0.2)
            returncode = process.wait() if process.poll() is None else process.returncode
            new_states = ([resume_state] if resume_state else [path for path in state_dir.glob("*.state") if path not in baseline_states])
            if new_states:
                selected_state = max(new_states, key=lambda path: path.stat().st_mtime_ns)
                last_state = snapshot_state(selected_state, events, last_state)
    except (OSError, subprocess.SubprocessError) as exc:
        if process is not None and process.poll() is None:
            try:
                terminate_process_group(process)
                terminate_recorded_reviewer_group(state_dir, selected_state)
            except (OSError, subprocess.SubprocessError):
                pass
        returncode = process.returncode if process and process.returncode is not None else 125
        (evidence / "adapter-error.txt").write_text(str(exc) + "\n")

    if args.resume_review_id:
        try:
            (state_dir / f"{args.resume_review_id}.lock.resume-guard").rmdir()
        except (FileNotFoundError, OSError):
            pass

    elapsed = round(time.monotonic() - started, 3)
    if runtime_plan.exists():
        shutil.copy2(runtime_plan, evidence / "PLAN.after.md")
        if external_plan:
            shutil.copy2(runtime_plan, plan)
    plan_restore_error = restore_pending_plan() if external_plan else None

    state = parse_state(selected_state) if selected_state else {}
    review_id = state.get("review_id")
    valid_review_id = bool(review_id and re.fullmatch(r"[0-9]{8}-[0-9]{6}-[0-9a-f]{6}", review_id))
    state_identity_valid = bool(valid_review_id and selected_state and selected_state.stem == review_id)
    findings_files: list[Path] = []
    findings_dir: Path | None = None
    evidence_state: Path | None = None
    evidence_review_dir: Path | None = None
    copy_errors: list[str] = []
    if plan_restore_error:
        copy_errors.append(f"repository PLAN.md restoration failed: {plan_restore_error}")
    if state_identity_valid:
        findings_dir = state_dir / str(review_id)

        def finding_round(path: Path) -> int:
            match = re.search(r"findings-round-(\d+)\.md$", path.name)
            return int(match.group(1)) if match else -1

        findings_files = sorted(findings_dir.glob("findings-round-*.md"), key=finding_round) if findings_dir.is_dir() else []
        if selected_state:
            evidence_state = evidence / "artifacts" / selected_state.name
            try:
                copy_if_exists(selected_state, evidence_state)
            except OSError as exc:
                copy_errors.append(f"state evidence copy failed: {exc}")
        evidence_review_dir = evidence / "artifacts" / str(review_id)
        try:
            copy_if_exists(findings_dir, evidence_review_dir)
        except OSError as exc:
            copy_errors.append(f"generation evidence copy failed: {exc}")
    try:
        copy_if_exists(state_dir / "log", evidence / "artifacts" / "claudex.log")
    except OSError as exc:
        copy_errors.append(f"log evidence copy failed: {exc}")

    final_findings = findings_files[-1] if findings_files else None
    findings_status, severity = final_findings_status(final_findings)
    phase = state.get("phase")
    decision = state.get("decision_signal")
    sweep: dict[str, Any] | None = None
    if timed_out or externally_interrupted:
        if args.engine == "sweep-v2" and state_identity_valid and evidence_state and evidence_review_dir and not copy_errors:
            sweep = validate_sweep(
                evidence_state, evidence_review_dir, findings_dir, runtime_plan,
                evidence / "PLAN.after.md", args.rounds, args.topic.strip(),
            )
            state = sweep["state"]
            phase = state.get("phase")
            decision = state.get("decision_signal")
            findings_status = sweep["findings_status"]
            severity = sweep["severity_counts"]
        outcome = "timed_out"
        if externally_interrupted:
            signal_name = signal.Signals(_INTERRUPTED_SIGNAL).name if _INTERRUPTED_SIGNAL is not None else "UNKNOWN"
            reason = f"adapter received {signal_name}; process group terminated and reaped; latest copied sweep progress was revalidated"
        else:
            reason = "wall-clock timeout exceeded; process group terminated and reaped; latest copied sweep progress was revalidated"
    elif returncode != 0:
        outcome = "failed"
        reason = f"Claude Code exited non-zero ({returncode})"
    elif not selected_state or not state:
        outcome = "degraded"
        reason = "Claude exited zero but no new Claudex state artifact was found"
    elif not state_identity_valid or findings_dir is None:
        outcome = "degraded"
        reason = "Claudex state filename and review_id are missing, malformed, or mismatched"
    elif copy_errors:
        outcome = "degraded"
        reason = "required adapter evidence could not be copied: " + "; ".join(copy_errors)
    elif args.engine == "review-v3":
        sweep = validate_review_v3(evidence_state, evidence_review_dir, runtime_plan, args.topic.strip())
        state = sweep["state"]
        phase = state.get("phase")
        decision = state.get("decision_signal")
        outcome = sweep["outcome"]
        reason = sweep["reason"]
        findings_status = sweep["findings_status"]
        severity = sweep["severity_counts"]
    elif args.engine == "sweep-v2":
        sweep = validate_sweep(
            evidence_state,
            evidence_review_dir,
            findings_dir,
            runtime_plan,
            evidence / "PLAN.after.md",
            args.rounds,
            args.topic.strip(),
        )
        state = sweep["state"]
        phase = state.get("phase")
        decision = state.get("decision_signal")
        outcome = sweep["outcome"]
        reason = sweep["reason"]
        findings_status = sweep["findings_status"]
        severity = sweep["severity_counts"]
    elif decision == "no-material-findings" and phase == "done" and findings_status == "none":
        outcome = "converged"
        reason = "terminal legacy state and final findings agree that no substantive findings remain"
    elif decision == "max-reached" and phase == "done" and findings_status in {"material", "unparseable"}:
        outcome = "max_reached"
        reason = "legacy round budget exhausted without an authoritative clean findings artifact"
    else:
        outcome = "degraded"
        reason = f"legacy state/artifact mismatch or incomplete lifecycle (phase={phase}, signal={decision}, findings={findings_status})"

    copied_final = None
    if final_findings and evidence_review_dir:
        copied_final = evidence_review_dir / final_findings.name
    copied_consolidated = None
    copied_manifest = None
    copied_generation_dir = None
    if sweep and evidence_review_dir and sweep.get("generation"):
        generation_candidate = evidence_review_dir / "generations" / str(sweep["generation"])
        if generation_candidate.is_dir():
            copied_generation_dir = generation_candidate
            consolidated_candidate = generation_candidate / "consolidated-findings.md"
            manifest_candidate = generation_candidate / "manifest.json"
            copied_consolidated = consolidated_candidate if consolidated_candidate.is_file() else None
            copied_manifest = manifest_candidate if manifest_candidate.is_file() else None

    stream_summary = parse_claude_stream(stdout_path)
    result = {
        "schema_version": 1,
        "outcome": outcome,
        "clean": outcome == "converged",
        "reason": reason,
        "engine": args.engine,
        "repo": str(repo),
        "plan": str(plan),
        "review_id": review_id,
        "phase": phase,
        "decision_signal": decision,
        "generation": sweep.get("generation") if sweep else None,
        "max_generations": sweep.get("max_generations") if sweep else None,
        "snapshot_sha256": sweep.get("snapshot_sha256") if sweep else None,
        "converged_snapshot_sha256": sweep.get("converged_snapshot_sha256") if sweep else None,
        "persona_coverage": sweep.get("persona_coverage", []) if sweep else [],
        "generation_manifest": str(copied_manifest) if copied_manifest else None,
        "generation_evidence_dir": str(copied_generation_dir) if copied_generation_dir else None,
        "consolidated_findings": str(copied_consolidated) if copied_consolidated else None,
        "findings_registry": str(copied_generation_dir / "findings-registry.json") if copied_generation_dir and (copied_generation_dir / "findings-registry.json").is_file() else None,
        "round": int(state["round"]) if args.engine == "legacy" and state.get("round", "").isdigit() else None,
        "max_rounds": int(state["max_rounds"]) if args.engine == "legacy" and state.get("max_rounds", "").isdigit() else (args.rounds if args.engine == "legacy" else None),
        "findings_status": findings_status,
        "severity_counts": severity,
        "final_findings": str(final_findings) if final_findings else None,
        "evidence_final_findings": str(copied_final) if copied_final else None,
        "evidence_dir": str(evidence),
        "stdout_log": str(stdout_path),
        "stderr_log": str(stderr_path),
        "state_file": str(selected_state) if selected_state else None,
        "evidence_state_file": str(evidence_state) if evidence_state else None,
        "source_state_file": str(selected_state) if selected_state else None,
        "elapsed_seconds": elapsed,
        "process_exit_code": returncode,
        "budget_usd": str(budget),
        "reported_claude_cost_usd": stream_summary.get("reported_cost_usd"),
        "claude_session_id": stream_summary.get("session_id"),
    }
    (evidence / "result.json").write_text(json.dumps(result, indent=2, sort_keys=True) + "\n")
    for handled_signal, previous_handler in previous_signal_handlers.items():
        signal.signal(handled_signal, previous_handler)
    release_adapter_lock()
    return emit(result, EXIT_CODES[outcome])


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as exc:
        restore_error = restore_pending_plan()
        release_adapter_lock()
        message = f"unexpected adapter failure: {type(exc).__name__}: {exc}"
        if restore_error:
            message += f"; repository PLAN.md restoration also failed: {restore_error}"
        sys.exit(fail(message, kind="internal"))
